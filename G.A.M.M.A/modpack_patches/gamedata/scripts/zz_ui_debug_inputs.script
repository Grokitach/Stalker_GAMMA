	local on_exec = ui_debug_launcher.UIDebug_ObjSpawn.OnButton_Name
	ui_debug_launcher.UIDebug_ObjSpawn.OnButton_Name = function(self)
		on_exec(self)
		add_input({"ui_debug_launcher", "UIDebug_ObjSpawn", "d13_input"}, self.d13_input:GetText())
