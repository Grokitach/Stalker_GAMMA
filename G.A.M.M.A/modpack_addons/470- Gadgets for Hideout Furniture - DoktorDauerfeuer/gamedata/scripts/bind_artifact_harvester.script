    ["af_mincer_meat"] = 0.028,
    ["af_ice"] = 0.014,
    ["af_sponge"] = 0.014,
    ["af_pin"] = 0.014,
    ["af_gravi"] = 0.014,
    ["af_baloon"] = 0.014,
    ["af_cristall"] = 0.014,
    ["af_fire"] = 0.014,
