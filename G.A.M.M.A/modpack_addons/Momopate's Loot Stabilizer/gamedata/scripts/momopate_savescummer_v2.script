	printf("/// SAVESCUMMER: WPO is loaded!")
	
	function zzzz_arti_jamming_repairs.weapon_eval_parts(wpn)
		seed = generate_seed_weapon(wpn)
		
--		if (seed == AC_ID) then
--			seed = wpn:id()
--		end
		
		mrs(seed, "Weapon parts generation")
		
		create_parts(wpn)
		mrs(dtg())
	end
	
