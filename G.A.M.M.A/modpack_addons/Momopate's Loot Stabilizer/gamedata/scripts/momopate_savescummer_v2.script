local function generate_seed_weapon(obj)
	local seed_hour = level.get_time_hours()
	local seed_lvl = maps[level.name()] or 5
	local parent_id = obj:parent() and obj:parent():id() or 2
	if parent_id then
		local seed_parent_last_digit = tonumber(string.sub(parent_id,-1)) or 2
	else
		local seed_parent_last_digit = 2
	end

	local seed_weapon_name = last_char_as_number(obj:id()) or 8

	return seed_parent_last_digit .. seed_weapon_name .. seed_hour .. seed_lvl
end

if zzzz_arti_jamming_repairs then												-- Check if you have WPO installed, version shouldn't matter question mark.
	
	local create_parts	= zzzz_arti_jamming_repairs.weapon_eval_parts			-- Do part condition rolls
