                    {id = "volume_gear_rustle_sounds", type = "track", val = 2, min = 0, max = 1, step = 0.05, def = 0.5},
                    {id = "volume_servo_sounds", type = "track", val = 2, min = 0, max = 1, step = 0.05, def = 0.5},

