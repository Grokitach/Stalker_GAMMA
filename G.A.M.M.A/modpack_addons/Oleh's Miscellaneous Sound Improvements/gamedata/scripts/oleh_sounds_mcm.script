                    {id = "enabled_crawl_sounds", type = "check", val = 1, def = true},
                    {id = "volume_crawl_sounds", type = "track", val = 2, min = 0, max = 1, step = 0.05, def = 0.5},
                }
            },
            {
                id = "weapons",
