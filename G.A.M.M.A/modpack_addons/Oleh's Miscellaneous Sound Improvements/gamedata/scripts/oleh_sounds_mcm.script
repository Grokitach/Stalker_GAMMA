                    {id = "title", type = "slide", link = "ui_options_slider_gameplay_diff", text = "ui_mcm_title_oleh_sounds_weapons", size = {512, 50}, spacing = 20},

                    {id = "volume_gunfire", type = "track", val = 2, min = 0, max = 2, step = 0.05, def = 1},
