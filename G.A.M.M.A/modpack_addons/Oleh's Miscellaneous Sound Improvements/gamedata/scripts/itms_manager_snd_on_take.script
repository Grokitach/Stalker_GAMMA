debug = false

local timeout_tg = 0
local timeout_duration = 1
local def_timeout_duration = 1

function itms_manager.print_dbg(txt, ...)
	if debug then
		printf("[itms_manager_snd_on_take] " .. txt, ...)
	end
end

-- call this function to temporarily disable pickup sounds
function itms_manager.timeout_snd_on_take(duration)
	timeout_tg = time_global()
	timeout_duration = duration or def_timeout_duration
end

