local enabled = true
local base_vol = 1

local time_snd_prev = 0
play_item_sound = itms_manager.play_item_sound
function itms_manager.play_item_sound(item, vol)
	if not enabled then return end
	if (not item) then
		printe("!ERROR itms_manager_snd_on_take | play_item_sound | no object recieved!")
		return
	end

	local snd_type = SYS_GetParam(0,item:section(),"snd_on_take")
	if not (snd_type and snd_type ~= "") then
		return
	end

	local snd = snd_on_take[snd_type]
	-- oleh5230
	if snd_type == "weapon" then
		snd = snd_on_take[SYS_GetParam(0,item:section(),"kind") or "w_rifle"]
	end
	-- oleh5230 end
	if (not snd) then
		return
	end

	local snd_obj
	if (#snd == 1) then
		snd_obj = sound_object(snd[1])
	else
		snd_obj = sound_object(snd[1] .. tostring(math.random(snd[2],snd[3])))
	end

	local time_g = time_global()
	itms_manager.print_dbg("itms_manager_snd_on_take timeout: %s %s", time_g, timeout_tg)
	if snd_obj and (time_g > time_snd_prev + 25) and (time_g > timeout_tg + timeout_duration) then
		snd_obj:play(db.actor,0,sound_object.s2d)
		snd_obj.volume = vol and base_vol * vol or base_vol
		timeout_duration = def_timeout_duration
	end
	time_snd_prev = time_g
end

local time_snd_prev2 = 0
function itms_manager.play_use_sound(item, vol)
	if (not item) then
		printe("!ERROR itms_manager_snd_on_take | play_use_sound | no object recieved!")
		return
	end

	local snd_type = SYS_GetParam(0,item:section(),"snd_on_use")
	if not (snd_type and snd_type ~= "") then
		return
	end

	local snd = snd_on_use[snd_type]
	if (not snd) then
		return
	end

	local snd_obj
	if (#snd == 1) then
		snd_obj = sound_object(snd[1])
	else
		snd_obj = sound_object(snd[1] .. tostring(math.random(snd[2],snd[3])))
	end

	local time_g = time_global()
	if snd_obj and (time_g > time_snd_prev2 + 200) then
		snd_obj:play(db.actor,0,sound_object.s2d)
		snd_obj.volume = vol and base_vol * vol or base_vol
	end
	time_snd_prev2 = time_g
end

-- fix for items spawned after opening a container
function GUI_on_show(name)
	if name == "UIInventory" and ui_inventory.GUI and ui_inventory.GUI.mode == "loot" then
		-- increased duration for demonized exes' ammo aggregation
		itms_manager.print_dbg("UIInventory timeout")
		itms_manager.timeout_snd_on_take(250)

	-- elseif name == "UIMutantLoot" and ui_mcm and ui_mcm.get("fddar/skinning/auto_loot_all") then
	-- 	itms_manager.print_dbg("UIMutantLoot timeout")
	-- 	itms_manager.timeout_snd_on_take()
	end
end

function GUI_on_hide(name)
	-- fix for ammo spawned by ammo wheel 
	if name == "UIWheelAmmo" then
		itms_manager.print_dbg("UIWheelAmmo timeout")
		itms_manager.timeout_snd_on_take()

	-- patch for mutant skinning (to not interfere with FDDAR)
	elseif name == "UIMutantLoot" then
		if ui_mcm and ui_mcm.get("fddar/skinning/enable") then
			itms_manager.print_dbg("UIMutantLoot timeout")
			itms_manager.timeout_snd_on_take()
		end
	end
end

-- fix for items spawned upon item use (to not interfere with FDDA)
function actor_on_item_use()
	itms_manager.print_dbg("actor_on_item_use timeout")
	itms_manager.timeout_snd_on_take()
end

-- fix for headgear/backpack equip (to not interfere with FDDAR)
-- unused, fixed in ui_inventory
function actor_item_equip(obj)
	if (IsHeadgear(obj) and ui_mcm and ui_mcm.get("fddar/headgear_anm/enable"))
	or (IsItem("backpack", nil, obj) and ui_mcm and ui_mcm.get("fddar/outfit_anm/enable_backpack_equip")) then
		itms_manager.print_dbg("actor_item_equip timeout")
		itms_manager.timeout_snd_on_take()
	end
end

function load_mcm_options()
    if ui_mcm and oleh_sounds_mcm then
        enabled = ui_mcm.get("oleh_sounds/inventory/enabled_inventory_pickup")
        base_vol = ui_mcm.get("oleh_sounds/inventory/volume_inventory_pickup") or 1
    -- old MCM compatibility
    elseif ui_mcm and oleh_misc_sounds_mcm then
        enabled = ui_mcm.get("oleh_misc_sounds/enabled_inventory_pickup")
        base_vol = ui_mcm.get("oleh_misc_sounds/volume_inventory_pickup") or 1
    end
end

function actor_on_update()
	itms_manager.print_dbg("!%s", timeout_duration)
end

function on_game_start()
	--RegisterScriptCallback("actor_on_update", actor_on_update)
	RegisterScriptCallback("GUI_on_show", GUI_on_show)
	RegisterScriptCallback("GUI_on_hide", GUI_on_hide)
	RegisterScriptCallback("actor_on_item_use", actor_on_item_use)
	--RegisterScriptCallback("actor_item_to_slot", actor_item_equip)
	--RegisterScriptCallback("actor_item_to_ruck", actor_item_equip)
    RegisterScriptCallback("on_option_change", load_mcm_options)
    load_mcm_options()
end