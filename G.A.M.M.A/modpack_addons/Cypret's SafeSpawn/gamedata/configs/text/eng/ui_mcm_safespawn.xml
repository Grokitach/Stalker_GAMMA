<?xml version="1.0" encoding="windows-1251"?>
<string_table>
    <string id="ui_mcm_menu_safespawn">
        <text>SafeSpawn</text>
    </string>

    <string id="ui_mcm_safespawn_show_messages">
        <text>Enable PDA Notifications</text>
    </string>
    <string id="ui_mcm_safespawn_show_messages_desc">
        <text>Show alerts when hostiles are siloed or restored.</text>
    </string>

    <string id="ui_mcm_safespawn_radius">
        <text>Detection Radius (Meters)</text>
    </string>
    <string id="ui_mcm_safespawn_radius_desc">
        <text>The distance around your spawn point to check for hostile humans - default is 6 meters.</text>
    </string>

    <string id="ui_mcm_safespawn_random_duration">
        <text>Enable Randomized Duration</text>
    </string>
    <string id="ui_mcm_safespawn_random_duration_desc">
        <text>If enabled, the script will pick a random arrival time between the Min and Max values below. If disabled, it uses the 'Static Duration' slider.</text>
    </string>

    <string id="ui_mcm_safespawn_duration">
        <text>Static Duration (Seconds) - default is 30</text>
    </string>

    <string id="ui_mcm_safespawn_duration_min">
        <text>Random Duration: Minimum</text>
    </string>

    <string id="ui_mcm_safespawn_duration_max">
        <text>Random Duration: Maximum</text>
    </string>

    <string id="ui_mcm_safespawn_debug">
        <text>Enable Debug</text>
    </string>

	<string id="ui_mcm_safespawn_debug_desc">
        <text>If enabled, the mod will print activation messages on every level transition regardless of enemy presence - for testing modded transit points.</text>
    </string>
</string_table>