    ["materials\\fake_slide"]          = "default_", -- Материал для колижена (нет звука, следов от пуль, теней)

    ["objects\\large_furniture"]       = "wood_", -- Red Forest tunnel planks
    ["objects\\large_metal_trash"]     = "metal_", -- Limansk bridge
}

function print_dbg(...)
	if debug then
		printf(...)
	end
end