    ["materials\\bush_sux"]            = "bush_", -- Кусты, крона деревьев, камышы, листья сухие
    ["materials\\cloth"]               = "grass_", -- Ткань
    ["materials\\concrete"]            = "concrete_", -- Монолитный бетон
    ["materials\\death"]               = "earth_", -- Смертоносная земля (нестандартный материал)
    ["materials\\dirt"]                = "earth_", -- Мокрая грязь, болото 
    ["materials\\earth"]               = "earth_", -- Сухая твердая земля (стандартный материал)
    ["materials\\earth_death"]         = "earth_", -- Сухая твердая земля (нестандартный материал)
    ["materials\\earth_slide"]         = "earth_", -- Сухая твердая земля (стандартный материал)
    ["materials\\flooring_tile"]       = "tile_", -- Плитка, кафель
    ["materials\\glass"]               = "tile_", -- Стекло
    ["materials\\grass"]               = "grass_", -- Земля, покрытая травой
    ["materials\\gravel"]              = "gravel_", -- Гравий
    ["materials\\metal"]               = "metal_", -- Монолитный метал, толстый кусок железа, танк
    ["materials\\metal_pipe"]          = "metal_", -- Металлическая труба
    ["materials\\metal_plate"]         = "metal_", -- Металлическая пластина (толщина 2-5см), Ступеньки
    ["materials\\sand"]                = "gravel_", -- Песок, насыпь
    ["materials\\setka_rabica"]        = "metal_plate_", -- Сетка рабица, колючая проволока
    ["materials\\shifer"]              = "tile_", -- Шифер
    ["materials\\stucco"]              = "asphalt_", -- штукатурка
    ["materials\\tin"]                 = "metal_", -- Жесть, крыша домов
