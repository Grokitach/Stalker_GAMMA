function on_game_start()
    if weapon_cover_tilt and weapon_cover_tilt.add_callback then
        local wct = weapon_cover_tilt
        wct.add_callback("actor_on_weapon_before_tilt", function(wpn, flags)
            if IsMoveState('mcSprint') then
                flags.enabled = false
            end
        end)
    end
end